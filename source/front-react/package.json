{
  "name": "front-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "test:e2e": "node e2e/console-resize.mjs",
    "build": "pnpm run build:ts && pnpm run build:vite",
    "build:ts": "tsc -b",
    "build:vite": "vite build",
    "preview": "vite preview",
    "build:tests": "tsc -p tsconfig.tests.json",
    "test": "pnpm run build:tests && node scripts/run-tests.mjs",
    "biome:lint": "biome lint .",
    "biome:format": "biome format --write .",
    "biome:check": "biome check .",
    "biome:fix": "biome check --write .",
    "biome:ci": "biome ci ."
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "0.12.0-beta.256",
    "@xterm/addon-webgl": "0.20.0-beta.255",
    "@xterm/xterm": "6.1.0-beta.256",
    "devicon": "^2.17.0",
    "highlight.js": "^11.11.1",
    "iconoir-react": "^7.11.0",
    "monaco-editor": "^0.54.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.4",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@eslint/js": "^9.36.0",
    "@tailwindcss/vite": "^4.1.16",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.1.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7"
  }
}
