# Root environment for `docker compose` (source/docker-compose.yaml).
#
# Docker Compose reads this file automatically and substitutes ${VAR} in the
# compose file. setup.sh creates source/.env from this template, filling in
# random secrets, and keeps the shared values in sync with web_service/.env.
#
# Per-service runtime config still lives in web_service/.env and vm_service/.env;
# when present those take precedence for their own service.

# --- Postgres credentials -------------------------------------------------- #
# Used by the `db` service (POSTGRES_*) and the `web` service (DB_*). Both read
# the same values so they always agree. DB_PASSWORD is a stable default on
# purpose (not randomized): Postgres only applies POSTGRES_PASSWORD on the FIRST
# init of its volume, so a value that changes between runs breaks login on an
# existing .db_data/. Set a custom one only if you'll manage the volume yourself.
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=mypassword
DB_HOST=db
DB_PORT=5432

# --- Django secret --------------------------------------------------------- #
# Consumed by the web service. setup.sh generates a random value and mirrors it
# into web_service/.env (which the web container actually reads at runtime).
SECRET_KEY=CHANGEME

# --- HTTP port ------------------------------------------------------------- #
# External port the stack is served on (nginx host mapping). Change it here only;
# Django reads it too, so CSRF keeps working (e.g. set 81 -> http://localhost:81).
HTTP_PORT=80

# --- Public hostnames ------------------------------------------------------ #
# Comma-separated Host headers Django answers to. "web", "localhost" and
# "127.0.0.1" are always allowed (INTERNAL_HOSTS in web_service/pequeroku/
# settings.py), so this is only for whatever else ends up in the browser's URL:
# a LAN IP, an mDNS name, a public domain. Every entry is also trusted as a CSRF
# origin, so login and forms keep working from it:
#   ALLOWED_HOSTS=192.168.1.50,zimaboard.local,pequeroku.example.com
# "*" answers to any Host — the default, so self-hosting over a LAN works with no
# edit. Narrow it to real hostnames before exposing the stack to the internet.
# Leave it EMPTY to allow only the internal hosts above.
#
# Set it HERE, not in web_service/.env: compose passes this value into the web
# container's environment, and that always wins over the per-service .env file.
ALLOWED_HOSTS=*
